# ===== 模型 / provider 选择（运行时切换）=====
# 按"第三方端点说什么协议"来选：
#   openai     —— OpenAI 官方模型（默认）。需要 OPENAI_API_KEY。SDK 默认就走 Responses API。
#   responses  —— Responses 协议第三方端点（暴露 /v1/responses）。需 OPS_QA_BASE_URL + OPS_QA_API_KEY + OPS_QA_MODEL。
#   compatible —— Chat Completions 协议第三方端点（暴露 /v1/chat/completions）。需 OPS_QA_BASE_URL + OPS_QA_API_KEY + OPS_QA_MODEL。
#   anthropic  —— Anthropic 协议第三方端点（暴露 /v1/messages，即 ops-qa-bot 用的那种 Claude 代理）。需装 [litellm] extra。
#   litellm    —— 通用兜底：经 LiteLLM 直连任意 provider，模型名要带前缀（anthropic/、gemini/...）。需装 [litellm] extra。
OPS_QA_PROVIDER=openai

# 模型名。缺省随 provider 变：
#   openai→gpt-5  compatible→claude-opus-4-8  anthropic→claude-opus-4-8  litellm→anthropic/claude-opus-4-8
# OPS_QA_MODEL=gpt-5

# --- provider=openai 时（官方，默认即 Responses API）---
# OPENAI_API_KEY=sk-...

# --- provider=responses 时（Responses 协议 /v1/responses 的第三方代理）---
# OPS_QA_BASE_URL=https://your-proxy.example.com/v1         # client 会追加 /responses；填完整 .../responses 也会自动剥掉
# OPS_QA_API_KEY=sk-...
# OPS_QA_MODEL=gpt-5

# --- provider=compatible 时（Chat Completions 协议的第三方代理）---
# OPS_QA_BASE_URL=https://your-proxy.example.com/v1
# OPS_QA_API_KEY=sk-...
# OPS_QA_MODEL=claude-opus-4-8

# --- provider=anthropic 时（Anthropic /v1/messages 协议的第三方代理）---
# OPS_QA_BASE_URL=https://your-anthropic-proxy.example.com   # 省略则打 Anthropic 官方
# OPS_QA_API_KEY=sk-ant-...                                  # 省略则回退 ANTHROPIC_API_KEY
# OPS_QA_MODEL=claude-opus-4-8                               # 会自动补成 anthropic/claude-opus-4-8

# --- provider=litellm 时（通用，模型名自带前缀）---
# OPS_QA_API_KEY=sk-...
# OPS_QA_BASE_URL=https://your-proxy.example.com             # 可选
# OPS_QA_MODEL=anthropic/claude-opus-4-8

# ===== 实例：火山引擎 coding plan，同账号两种格式都可 =====
# OpenAI 格式（端点 .../api/coding/v3）——推荐，标准 Bearer 鉴权，最省心：
#   OPS_QA_PROVIDER=compatible
#   OPS_QA_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3   # client 追加 /chat/completions
#   OPS_QA_API_KEY=<你的火山 ARK key>
#   OPS_QA_MODEL=<模型名或 endpoint-id>
# Anthropic 格式（端点 .../api/coding）——火山要 Bearer，所以 OPS_QA_ANTHROPIC_AUTH=bearer：
#   OPS_QA_PROVIDER=anthropic
#   OPS_QA_BASE_URL=https://ark.cn-beijing.volces.com/api/coding      # litellm 追加 /v1/messages
#   OPS_QA_API_KEY=<你的火山 ARK key>
#   OPS_QA_ANTHROPIC_AUTH=bearer
#   OPS_QA_MODEL=<模型名>

# ===== 实例：智谱 BigModel（GLM），同账号两种格式都可 =====
# OpenAI 格式（端点 https://open.bigmodel.cn/api/paas/v4/chat/completions）：
#   OPS_QA_PROVIDER=compatible
#   OPS_QA_BASE_URL=https://open.bigmodel.cn/api/paas/v4    # 也可直接粘完整 URL，会自动剥掉 /chat/completions
#   OPS_QA_API_KEY=<你的智谱 key>
#   OPS_QA_MODEL=glm-4.6
# Anthropic 格式（端点 https://open.bigmodel.cn/api/anthropic，litellm 自动补 /v1/messages）：
#   OPS_QA_PROVIDER=anthropic
#   OPS_QA_BASE_URL=https://open.bigmodel.cn/api/anthropic
#   OPS_QA_API_KEY=<你的智谱 key>
#   OPS_QA_MODEL=glm-4.6                                    # 自动补成 anthropic/glm-4.6

# ── 答题模式 ───────────────────────────────────────────────
# 编排模式：single（单 agent）/ multi（分诊→专家）/ coordinator（跨组件协调）/
# auto（自适应，默认）。终端与飞书共用；终端可用 --mode 覆盖，飞书(run_ws.py)只认此变量。
# 缺省 auto，一般不用设。
# OPS_QA_MODE=auto

# ── 按角色的调用参数（ModelSettings）──────────────────────
# 采样温度：角色级 > 全局 > 代码默认（triage=0.1 路由要稳，其余不下发）。
# 角色 = TRIAGE / COORDINATOR / SINGLE / 组件目录大写（如 REDIS）。
# OPS_QA_TEMPERATURE=0.3
# OPS_QA_TEMPERATURE_TRIAGE=0.0
# coordinator 并行咨询专家的开关，缺省开；端点不认 parallel_tool_calls 参数时设 0。
# OPS_QA_PARALLEL_TOOLS=1
# 转交剥噪音开关，缺省开：handoff 时剥掉历史里的工具 dump（跨组件多轮省 token）。
# 短对话 + 单组件深聊时可设 0（带着已读文档比重读便宜）。
# OPS_QA_HANDOFF_STRIP_TOOLS=1

# ── 会话历史持久化（SDK Session / SQLite）──────────────────
# 多轮对话历史的 SQLite 落盘路径。缺省内存态（重启即丢）。
# 设成文件路径后：飞书 bot 重启 / 会话空闲回收后，同一 (chat,user) 的上下文可恢复接着聊。
# OPS_QA_SESSION_DB=.sessions.db

# ── 飞书长连接接入（run_ws.py，需 uv sync --extra feishu）────
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx

# ── 护栏 + 写操作审批（HITL，飞书/终端共用）────────────────
# 开启输入注入护栏 + 写操作审批闭环（飞书发审批卡片等值班人点按钮）。缺省关。
# OPS_QA_GUARDRAILS=1
# 审批人白名单（逗号分隔 open_id）；不设则群内任何人可拍板（演示用，生产务必设）。
# OPS_QA_APPROVERS=ou_xxx,ou_yyy
# 审批超时秒数，无人拍板自动驳回（安全默认）。缺省 600。
# OPS_QA_APPROVAL_TIMEOUT=600
