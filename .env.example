# ===== 模型 / provider 选择（运行时切换）=====
# 按"第三方端点说什么协议"来选：
#   openai     —— OpenAI 官方模型（默认）。需要 OPENAI_API_KEY。SDK 默认就走 Responses API。
#   responses  —— Responses 协议第三方端点（暴露 /v1/responses）。需 OPS_QA_BASE_URL + OPS_QA_API_KEY + OPS_QA_MODEL。
#   compatible —— Chat Completions 协议第三方端点（暴露 /v1/chat/completions）。需 OPS_QA_BASE_URL + OPS_QA_API_KEY + OPS_QA_MODEL。
#   anthropic  —— Anthropic 协议第三方端点（暴露 /v1/messages，即 ops-qa-bot 用的那种 Claude 代理）。需装 [litellm] extra。
#   litellm    —— 通用兜底：经 LiteLLM 直连任意 provider，模型名要带前缀（anthropic/、gemini/...）。需装 [litellm] extra。
OPS_QA_PROVIDER=openai

# 模型名。缺省随 provider 变：
#   openai→gpt-5  compatible→claude-opus-4-8  anthropic→claude-opus-4-8  litellm→anthropic/claude-opus-4-8
# OPS_QA_MODEL=gpt-5

# --- provider=openai 时（官方，默认即 Responses API）---
# OPENAI_API_KEY=sk-...

# --- provider=responses 时（Responses 协议 /v1/responses 的第三方代理）---
# OPS_QA_BASE_URL=https://your-proxy.example.com/v1         # client 会追加 /responses；填完整 .../responses 也会自动剥掉
# OPS_QA_API_KEY=sk-...
# OPS_QA_MODEL=gpt-5

# --- provider=compatible 时（Chat Completions 协议的第三方代理）---
# OPS_QA_BASE_URL=https://your-proxy.example.com/v1
# OPS_QA_API_KEY=sk-...
# OPS_QA_MODEL=claude-opus-4-8

# --- provider=anthropic 时（Anthropic /v1/messages 协议的第三方代理）---
# OPS_QA_BASE_URL=https://your-anthropic-proxy.example.com   # 省略则打 Anthropic 官方
# OPS_QA_API_KEY=sk-ant-...                                  # 省略则回退 ANTHROPIC_API_KEY
# OPS_QA_MODEL=claude-opus-4-8                               # 会自动补成 anthropic/claude-opus-4-8

# --- provider=litellm 时（通用，模型名自带前缀）---
# OPS_QA_API_KEY=sk-...
# OPS_QA_BASE_URL=https://your-proxy.example.com             # 可选
# OPS_QA_MODEL=anthropic/claude-opus-4-8

# ===== 实例：火山引擎 coding plan，同账号两种格式都可 =====
# OpenAI 格式（端点 .../api/coding/v3）——推荐，标准 Bearer 鉴权，最省心：
#   OPS_QA_PROVIDER=compatible
#   OPS_QA_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3   # client 追加 /chat/completions
#   OPS_QA_API_KEY=<你的火山 ARK key>
#   OPS_QA_MODEL=<模型名或 endpoint-id>
# Anthropic 格式（端点 .../api/coding）——火山要 Bearer，所以 OPS_QA_ANTHROPIC_AUTH=bearer：
#   OPS_QA_PROVIDER=anthropic
#   OPS_QA_BASE_URL=https://ark.cn-beijing.volces.com/api/coding      # litellm 追加 /v1/messages
#   OPS_QA_API_KEY=<你的火山 ARK key>
#   OPS_QA_ANTHROPIC_AUTH=bearer
#   OPS_QA_MODEL=<模型名>

# ===== 实例：智谱 BigModel（GLM），同账号两种格式都可 =====
# OpenAI 格式（端点 https://open.bigmodel.cn/api/paas/v4/chat/completions）：
#   OPS_QA_PROVIDER=compatible
#   OPS_QA_BASE_URL=https://open.bigmodel.cn/api/paas/v4    # 也可直接粘完整 URL，会自动剥掉 /chat/completions
#   OPS_QA_API_KEY=<你的智谱 key>
#   OPS_QA_MODEL=glm-4.6
# Anthropic 格式（端点 https://open.bigmodel.cn/api/anthropic，litellm 自动补 /v1/messages）：
#   OPS_QA_PROVIDER=anthropic
#   OPS_QA_BASE_URL=https://open.bigmodel.cn/api/anthropic
#   OPS_QA_API_KEY=<你的智谱 key>
#   OPS_QA_MODEL=glm-4.6                                    # 自动补成 anthropic/glm-4.6

# ── 答题模式 ───────────────────────────────────────────────
# 编排模式：single（单 agent）/ multi（分诊→专家）/ coordinator（跨组件协调）/
# auto（自适应，默认）。终端与飞书共用；终端可用 --mode 覆盖，飞书(run_ws.py)只认此变量。
# 缺省 auto，一般不用设。
# OPS_QA_MODE=auto

# ── 按角色的调用参数（ModelSettings）──────────────────────
# 采样温度：角色级 > 全局 > 代码默认（triage=0.1 路由要稳，其余不下发）。
# 角色 = TRIAGE / COORDINATOR / SINGLE / 组件目录大写（如 REDIS）。
# OPS_QA_TEMPERATURE=0.3
# OPS_QA_TEMPERATURE_TRIAGE=0.0
# coordinator 并行咨询专家的开关，缺省开；端点不认 parallel_tool_calls 参数时设 0。
# OPS_QA_PARALLEL_TOOLS=1
# 转交剥噪音开关，缺省开：handoff 时剥掉历史里的工具 dump（跨组件多轮省 token）。
# 短对话 + 单组件深聊时可设 0（带着已读文档比重读便宜）。
# OPS_QA_HANDOFF_STRIP_TOOLS=1

# ── 会话历史持久化（SDK Session / SQLite）──────────────────
# 多轮对话历史的 SQLite 落盘路径。缺省内存态（重启即丢）。
# 设成文件路径后：飞书 bot 重启 / 会话空闲回收后，同一 (chat,user) 的上下文可恢复接着聊。
# OPS_QA_SESSION_DB=.sessions.db

# ── 飞书长连接接入（run_ws.py，需 uv sync --extra feishu）────
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx

# ── 护栏 + 写操作审批（HITL，飞书/终端共用）────────────────
# 开启输入注入护栏 + 写操作审批闭环（飞书发审批卡片等值班人点按钮）。缺省关。
# OPS_QA_GUARDRAILS=1
# 审批人白名单（逗号分隔 open_id）；不设则群内任何人可拍板（演示用，生产务必设）。
# OPS_QA_APPROVERS=ou_xxx,ou_yyy
# 审批超时秒数，无人拍板自动驳回（安全默认）。缺省 600。
# OPS_QA_APPROVAL_TIMEOUT=600

# ── 实时诊断（测试环境只读，飞书/终端共用）──────────────────
# 开启 run_diagnostic 工具：到测试环境机器跑只读命令、把实时状态叠加到基于文档的回答上。
# 缺省关（工具不挂载、prompt 不加章节）。终端也可用 --diagnostics 临时开启。
# 命令用白名单强制只读；识别到的写命令引导走 request_write_command 审批（需同时开 GUARDRAILS）；
# 毁灭性命令直接拒；生产机（名字带 prod/production/正式）直接拒。实现见 diagnostics.py。
# OPS_QA_DIAG=1
# 跳板机 ssh 别名（~/.ssh/config 里配好，如 jumphost）：底层用嵌套 ssh
#   `ssh <jumphost> "ssh <target> '<只读命令>'"` 到目标机执行。
# **不配则自动降级为「模拟执行」**（返回示例数据，方便本地/演示先跑起来，不碰真实机器）。
# OPS_QA_DIAG_JUMPHOST=jumphost
# 允许诊断的目标机白名单（逗号分隔，支持 glob，如 10.1.*,*-test-*）。不设=不限（仍拒生产）。
# 生产务必设，把可诊断范围收敛到测试网段/主机名。
# OPS_QA_DIAG_ALLOWED_HOSTS=10.1.*,*-test-*
# 单条命令执行超时秒数，缺省 15。
# OPS_QA_DIAG_TIMEOUT=15
# 强制模拟执行（即使配了 jumphost 也不真跑 ssh），调试/演示用。缺省关。
# OPS_QA_DIAG_MOCK=1
# 生产判定关键词（逗号分隔），缺省 prod,production,正式。命中即拒诊断。
# OPS_QA_DIAG_PROD_PATTERNS=prod,production,正式

# ── 数据库诊断（测试环境只读 + 参数变更审批，飞书/终端共用）──
# 开启 query_database 工具：用 DBA 预建的**只读账号**直连测试环境数据库实例跑诊断 SQL
# （SHOW PROCESSLIST / gv$ob_sql_audit / performance_schema…），实时状态叠加到答案上。
# 只读由数据库账号权限强制（不解析 SQL）；凭据经 MYSQL_PWD 注入、LLM 拿不到；
# 目标受 ALLOWED_HOSTS 白名单约束。缺省关（工具不挂载、prompt 不加章节）。见 db_query.py。
# OPS_QA_DB=1
# 允许连接的实例白名单（逗号分隔：IP / CIDR / 精确主机名）。真实模式下不设 = 全拒。
# OPS_QA_DB_ALLOWED_HOSTS=10.1.0.0/16,db-test-01
# 只读账号，按连接类型三套（mysql=原生 MySQL；ob_mysql/ob_oracle=OceanBase 两种租户模式）。
# **一套都没配时自动降级为「模拟数据」**（标注来源的假结果，方便本地/演示先跑通链路）。
# OPS_QA_DB_MYSQL_RO_USER=ro
# OPS_QA_DB_MYSQL_RO_PASSWORD=xxx
# OPS_QA_DB_OB_MYSQL_RO_USER=ro
# OPS_QA_DB_OB_MYSQL_RO_PASSWORD=xxx
# OPS_QA_DB_OB_ORACLE_RO_USER=ro
# OPS_QA_DB_OB_ORACLE_RO_PASSWORD=xxx
# 参数变更审批（request_db_change，需同时开 GUARDRAILS）：批准后要**真执行**再配 admin
# 账号；不配则批准后登记为"待 DBA 人工执行"（与 request_write_command 同一登记姿态）。
# OPS_QA_DB_MYSQL_ADMIN_USER=admin
# OPS_QA_DB_MYSQL_ADMIN_PASSWORD=xxx
# OPS_QA_DB_OB_MYSQL_ADMIN_USER=admin
# OPS_QA_DB_OB_MYSQL_ADMIN_PASSWORD=xxx
# OPS_QA_DB_OB_ORACLE_ADMIN_USER=admin
# OPS_QA_DB_OB_ORACLE_ADMIN_PASSWORD=xxx
# 单条查询超时秒数（缺省 30）/ 结果截断字符数（缺省 20000）/ 强制模拟（缺省关）。
# OPS_QA_DB_TIMEOUT=30
# OPS_QA_DB_MAX_CHARS=20000
# OPS_QA_DB_MOCK=1

# ── 网关链路排查（query_gateway_trace，飞书/终端共用）────────
# 开启后 bot 挂一个 query_gateway_trace 工具：用户报"访问域名/接口失败"并给出响应头里的
# Hi-Trace-Id 时，确定性地取这次请求的网关链路表（命中的路由、后端实例、realIP、状态码、
# 异常类型如 URL_NOT_MATCHED / UPSTREAM_NO_HOSTS），而不是靠读文档现拼 curl。
# 缺省关（工具不挂载、prompt 不加章节）。终端也可用 --gateway-trace 临时开启。
# 与 run_diagnostic / query_database 不同，它是**组件专属工具**：multi/auto/coordinator 模式下
# 只挂在下面 COMPONENT 指定的那个组件的专家上，别的专家物理上没有它（分诊台会加一条兜底
# 路由规则：问题里出现 Hi-Trace-Id 就不许落到别的单组件专家手里）。实现见 gateway_trace.py。
# OPS_QA_GW_TRACE=1
# cat 平台地址（不带 /cat/... 路径段），bot 会打 GET {BASE_URL}/cat/r/model/logview/
# unified-access-server?messageId=<Hi-Trace-Id>，返回应用层 gzip 的 logview 表。
# **不配则自动降级为「模拟链路数据」**（标注过的假表，方便本地/演示/评测先跑通链路）。
# OPS_QA_GW_TRACE_BASE_URL=http://10.164.200.155:8080
# 挂链路工具的组件目录名（INDEX.md 的「目录」列），缺省 gateway。
# **配错会静默失效**（专家照常建出来、工具没进去），启动时会打 WARNING 提示，注意看日志。
# OPS_QA_GW_TRACE_COMPONENT=gateway
# 单次 logview GET 超时秒数（缺省 15，接口很快）/ 返回体截断字符数（缺省 20000）/ 强制模拟。
# OPS_QA_GW_TRACE_TIMEOUT=15
# OPS_QA_GW_TRACE_MAX_CHARS=20000
# OPS_QA_GW_TRACE_MOCK=1

# ── 飞书文档问答（query_feishu_doc，飞书/终端共用）──────────
# 部分组件的运维知识维护在飞书文档而非本地 markdown（INDEX.md 里「来源」列填 feishu、
# 「飞书文档」列登记 doc token/url）。配上外部 /doc_qa 服务的地址后，bot 会给这些组件
# 挂一个 query_feishu_doc 工具（multi/auto 模式下是给它们各建一个只有这个工具的专家）。
# 缺省关：不配则这些组件不建专家、prompt 不加章节、问到它们回"不在覆盖范围"，零感知。
# 与 OPS_QA_DIAG 不同，这个特性**没有模拟模式**——假的知识库正是本 bot 要防的东西。
# bot 请求 POST {BASE_URL}/doc_qa，body {"docs": [...], "q": "...", "req_id": "..."}，
# 期望响应 {"ok": true, "answer": "<markdown>", "req_id": "..."}。
# OPS_QA_DOC_QA_BASE_URL=http://doc-qa.internal
# 上游鉴权 Bearer token；不设表示对端没开鉴权（仅可信内网）。
# OPS_QA_DOC_QA_TOKEN=xxx
# 单次调用超时秒数，缺省 60。/doc_qa 内部还要跑 agent + 拉文档图，比纯文本接口慢，留足余量。
# OPS_QA_DOC_QA_TIMEOUT=60

# ── 二次复核（另一模型证据核对，飞书/终端共用）──────────────
# 开启后：答完由**另一个模型**对答案做证据核对（引用文档内容 + 诊断输出），发现具体证据
# 矛盾则让答题者**重答一次**再交付；重答仍不过则低风险带 ⚠️ 复核提示、涉及诊断/写转人工。
# 缺省关。终端也可用 --review 临时开。走非流式路径。实现见 review.py。
# OPS_QA_REVIEW=1
# 复核者模型：建议指到与答题**不同**的模型（降低同错同漏）；缺省回退默认模型。
# OPS_QA_REVIEWER_MODEL=gpt-5
# 喂给复核者的证据（引用文档内容 + 诊断输出）截断上限，缺省 8000。
# OPS_QA_REVIEW_MAX_EVIDENCE=8000
